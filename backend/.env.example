# Variáveis de ambiente para a API

# Email Configuration (Gmail)
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_app  # Para Gmail, use uma senha de app específica
EMAIL_DESTINO=seu_email@email.com

# Pasta para salvar uploads
PASTA_UPLOADS=./uploads

# Configurações da API
FLASK_ENV=production
FLASK_DEBUG=False
PORT=8080

# CORS em produção
CORS_ORIGIN=https://seu-app.railway.app

# Google Sheets (opcional)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/d/.../usercontent.run
