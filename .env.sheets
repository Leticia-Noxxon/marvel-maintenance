# Google Sheets Integration (Cole a URL do seu Google Apps Script aqui)
# Para usar: execute o script: https://script.google.com/macros/s/[SEU_ID_AQUI]/usercontent
# Crie um Google Apps Script que receba POST e insira dados em um Sheet
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/usercontent

# Alternativamente, use Google Sheets API com autenticação
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=
